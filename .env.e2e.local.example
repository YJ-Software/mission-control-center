# Mission Control E2E test config — copy to .env.e2e.local and fill in.
# DO NOT COMMIT .env.e2e.local (matched by `.env*.local`).

# ── Static, set once ────────────────────────────────────────────────
E2E_LOCAL_PUBLIC_IP=                    # operator's fixed public IP, allowed by ufw
E2E_SSH_HOST=                           # throwaway VPS hostname (the dashboard host)
E2E_SSH_USER=root
E2E_SSH_KEY=~/.ssh/id_ed25519           # private half of the moniDev key

# ── Virtualizor enduser API ─────────────────────────────────────────
VIRTUALIZOR_PANEL=https://vps.twnoc.net
VIRTUALIZOR_API_KEY=
VIRTUALIZOR_API_PASS=
VIRTUALIZOR_VPS_ID=
VIRTUALIZOR_OS_TEMPLATE_ID=             # rebuild target OS (e.g. Ubuntu 24.04)

# ── WHMCS ──────────────────────────────────────────────────────────
WHMCS_LOGIN_URL=https://twnoc.net/whmcs/login
WHMCS_USER=
WHMCS_PASSWORD=

# ── Telegram pairing (gramjs MTProto user account) ─────────────────
TEST_TELEGRAM_BOT_TOKEN=                # bot the dashboard registers (NOT operator's personal bot)
TEST_BOT_USERNAME=@                     # bot's @username (with the @), used by gramjs sendMessage
TG_API_ID=                              # from my.telegram.org → API development tools
TG_API_HASH=
TG_USER_SESSION=                        # populated by `node scripts/e2e/twnoc/auth-telegram-user.mjs`

# ── Derived (set automatically; do not edit) ────────────────────────
PLAYWRIGHT_BASE_URL=                    # http://$E2E_SSH_HOST:3737 (set by run-e2e.mjs)

# >>> e2e dynamic
AUTH_PASSWORD=                          # rewritten by Phase 2 (whmcs-deploy.spec.ts)
# <<<
