# OpenClaw Gateway
# Token is auto-detected from ~/.openclaw/openclaw.json if not set here
OPENCLAW_GATEWAY_WS=ws://127.0.0.1:18789
OPENCLAW_GATEWAY_HTTP=http://127.0.0.1:18789
OPENCLAW_TOKEN=your-gateway-token-here

# Authentication
AUTH_PASSWORD=your-dashboard-password-here
AUTH_SECRET=generate-a-random-string-here

# Server
PORT=3737
HOST=127.0.0.1
